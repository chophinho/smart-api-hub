{
  "info": {
    "name": "Dynamic API - Full Feature Collection",
    "_postman_id": "12345678-abcd-efgh-ijkl-1234567890ab",
    "description": "Collection test full chức năng: Auth, CRUD, Query, Relationship, Health",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "2. Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. CRUD Users",
      "item": [
        {
          "name": "GET users (filter fields)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users?_fields=id,email"
          }
        },
        {
          "name": "POST user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new@gmail.com\",\n  \"password\": \"123456\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "PUT user (replace)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"updated@gmail.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{base_url}}/users/1"
          }
        },
        {
          "name": "PATCH user (partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            },
            "url": "{{base_url}}/users/1"
          }
        },
        {
          "name": "DELETE user (admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users/1"
          }
        }
      ]
    },
    {
      "name": "4. Advanced Query",
      "item": [
        {
          "name": "Pagination",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts?_page=1&_limit=5"
          }
        },
        {
          "name": "Sorting",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts?_sort=id&_order=desc"
          }
        },
        {
          "name": "Filtering",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts?views_gte=10&views_lte=100"
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts?q=hello"
          }
        }
      ]
    },
    {
      "name": "5. Relationships",
      "item": [
        {
          "name": "Expand (parent)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts?_expand=user"
          }
        },
        {
          "name": "Embed (child)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users?_embed=posts"
          }
        }
      ]
    }
  ]
}
